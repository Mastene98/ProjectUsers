    {
      "name": "PostNewClient",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.collectionVariables.set(\"nom\", pm.variables.replaceIn(\"{{$randomLastName}}\"));\r",
              "\r",
              "pm.collectionVariables.set(\"prenom\", pm.variables.replaceIn(\"{{$randomFirstName}}\"));\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Le status du code retour est 201\", function(){\r",
              "    pm.response.to.have.status(201)\r",
              "});\r",
              "\r",
              "var jsonData = pm.response.json()\r",
              "pm.collectionVariables.set(\"UserId\", jsonData.id)\r",
              "console.info(\" Le user créé a l identifiant \" + pm.collectionVariables.get(\"UserId\"));\r",
              "\r",
              "pm.test(\"Le temps de réponse est inférieur a 1000 ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
